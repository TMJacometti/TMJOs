#!/bin/sh
# TMJMenu first-run / every-login setup.
#
# Configura keybindings custom do TMJOs via gsettings:
#   Super+Space → tmjmenu (popup search)
#   Super+H     → tmjdock --toggle-hide (force hide/show da dock)
#
# Idempotente: re-rodar não causa duplicatas nem reverte custom mods
# do user (só insere os slots se ainda não existirem; redefine os
# campos do nosso próprio slot pra garantir).

set -e

MENU_SLOT="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/tmjmenu/"
HIDE_SLOT="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/tmjdock-hide/"

# Helper: garante slot está na lista `custom-keybindings`.
add_slot_to_list() {
    SLOT_PATH="$1"
    CURRENT=$(gsettings get org.gnome.settings-daemon.plugins.media-keys \
        custom-keybindings 2>/dev/null || echo "@as []")

    case "$CURRENT" in
        *"$SLOT_PATH"*)
            # Já está lá — no-op
            ;;
        *)
            if [ "$CURRENT" = "@as []" ] || [ "$CURRENT" = "[]" ]; then
                NEW_LIST="['$SLOT_PATH']"
            else
                # Delimitador "|" (não "/") porque $SLOT_PATH contém "/" e
                # quebra o sed quando usa "/" como delimitador.
                NEW_LIST=$(echo "$CURRENT" | sed "s|]\$|, '$SLOT_PATH']|")
            fi
            gsettings set org.gnome.settings-daemon.plugins.media-keys \
                custom-keybindings "$NEW_LIST" 2>/dev/null || true
            ;;
    esac
}

# Helper: configura name/command/binding de um slot.
configure_slot() {
    SLOT_PATH="$1"
    NAME="$2"
    COMMAND="$3"
    BINDING="$4"

    SCHEMA="org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:$SLOT_PATH"
    gsettings set "$SCHEMA" name    "$NAME"    2>/dev/null || true
    gsettings set "$SCHEMA" command "$COMMAND" 2>/dev/null || true
    gsettings set "$SCHEMA" binding "$BINDING" 2>/dev/null || true
}

# 1. Super+Space → tmjmenu
add_slot_to_list "$MENU_SLOT"
configure_slot "$MENU_SLOT" 'TMJMenu' 'tmjmenu' '<Super>space'

# 2. Super+Shift+H → tmjdock --toggle-hide
# Super+H sozinho conflita com o default "minimize window" do GNOME —
# quando user pressed Super+H, minimiza a janela ativa em vez de
# toggle dock. Super+Shift+H não tem default binding.
add_slot_to_list "$HIDE_SLOT"
configure_slot "$HIDE_SLOT" 'TMJDock Toggle Hide' 'tmjdock --toggle-hide' '<Super><Shift>h'

exit 0
