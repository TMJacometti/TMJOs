#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	@if [ ! -f vendor/tmjos_installed.png ]; then \
		echo ""; \
		echo "ERROR: vendor/tmjos_installed.png missing."; \
		echo "Run tools/vendor-installer.sh from repo root."; \
		echo ""; \
		exit 1; \
	fi

	# Ship the TMJOs-branded "Installation complete" image in our own
	# dir. Postinst uses dpkg-divert to redirect ubiquity's PNG path
	# to this file (reversible on package removal).
	mkdir -p debian/tmjos-installer/usr/share/tmjos-installer
	cp vendor/tmjos_installed.png \
		debian/tmjos-installer/usr/share/tmjos-installer/tmjos_installed.png

	# TMJOs-branded SVG pra substituir /usr/share/icons/hicolor/*/apps/ubiquity.svg
	# Postinst dpkg-divert + symlinks em 6 sizes (16, 22, 24, 32, 48, 64).
	cp vendor/tmjos-ubiquity.svg \
		debian/tmjos-installer/usr/share/tmjos-installer/tmjos-ubiquity.svg

	# Partitioner icons (4 PNGs 64x64 com branding TMJOs neon).
	# Postinst dpkg-divert /usr/share/ubiquity/pixmaps/partitioner/*.png
	mkdir -p debian/tmjos-installer/usr/share/tmjos-installer/partitioner
	cp vendor/partitioner/*.png \
		debian/tmjos-installer/usr/share/tmjos-installer/partitioner/

	# Banner installing — guardado pra uso futuro (tmjos-slideshow v1.4+).
	if [ -f vendor/tmjos-installing.png ]; then \
		cp vendor/tmjos-installing.png \
			debian/tmjos-installer/usr/share/tmjos-installer/; \
	fi
