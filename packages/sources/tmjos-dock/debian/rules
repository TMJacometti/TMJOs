#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	# /etc/skel/.config/plank/dock1/
	mkdir -p debian/tmjos-dock/etc/skel/.config/plank/dock1/launchers
	install -m644 files/plank-settings \
		debian/tmjos-dock/etc/skel/.config/plank/dock1/settings
	install -m644 files/launchers/*.dockitem \
		debian/tmjos-dock/etc/skel/.config/plank/dock1/launchers/

	# /etc/xdg/autostart/
	mkdir -p debian/tmjos-dock/etc/xdg/autostart
	install -m644 files/autostart/plank.desktop \
		debian/tmjos-dock/etc/xdg/autostart/plank.desktop
	install -m644 files/autostart/tmjos-first-run.desktop \
		debian/tmjos-dock/etc/xdg/autostart/tmjos-first-run.desktop
	install -m644 files/autostart/tmjos-dock-sync.desktop \
		debian/tmjos-dock/etc/xdg/autostart/tmjos-dock-sync.desktop

	# /usr/bin/
	mkdir -p debian/tmjos-dock/usr/bin
	install -m755 files/bin/tmjos-show-apps \
		debian/tmjos-dock/usr/bin/tmjos-show-apps
	install -m755 files/bin/tmjos-first-run \
		debian/tmjos-dock/usr/bin/tmjos-first-run
	install -m755 files/bin/tmjos-dock-sync \
		debian/tmjos-dock/usr/bin/tmjos-dock-sync

	# /usr/share/applications/
	mkdir -p debian/tmjos-dock/usr/share/applications
	install -m644 files/applications/tmjos-show-apps.desktop \
		debian/tmjos-dock/usr/share/applications/tmjos-show-apps.desktop
