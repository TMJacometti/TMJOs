#!/bin/sh
# postinst do tmjos-dock — atualiza desktop database pra Apps menu pegar
# o tmjos-show-apps.desktop sem precisar de logout.
set -e

case "$1" in
    configure)
        if command -v update-desktop-database >/dev/null 2>&1; then
            update-desktop-database --quiet /usr/share/applications || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
