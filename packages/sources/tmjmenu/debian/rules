#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	@if [ ! -f vendor/Cargo.toml ]; then \
		echo "ERROR: vendor/Cargo.toml missing. Run tools/vendor-tmjmenu.sh first."; \
		exit 1; \
	fi
	cd vendor && cargo build --release --offline --locked

override_dh_auto_install:
	mkdir -p debian/tmjmenu/usr/bin
	cp vendor/target/release/tmjmenu debian/tmjmenu/usr/bin/tmjmenu
	cp vendor/target/release/tmjdock debian/tmjmenu/usr/bin/tmjdock
	chmod +x debian/tmjmenu/usr/bin/tmjmenu \
	         debian/tmjmenu/usr/bin/tmjdock

	cp vendor/data/tmjmenu-first-run debian/tmjmenu/usr/bin/tmjmenu-first-run
	chmod +x debian/tmjmenu/usr/bin/tmjmenu-first-run

	mkdir -p debian/tmjmenu/usr/share/applications
	cp vendor/data/tmjmenu.desktop debian/tmjmenu/usr/share/applications/

	mkdir -p debian/tmjmenu/usr/share/metainfo
	cp vendor/data/br.com.tmjsistemas.tmjmenu.appdata.xml \
		debian/tmjmenu/usr/share/metainfo/

	mkdir -p debian/tmjmenu/usr/share/icons/hicolor/512x512/apps
	cp vendor/data/tmjmenu.png debian/tmjmenu/usr/share/icons/hicolor/512x512/apps/
	mkdir -p debian/tmjmenu/usr/share/icons/hicolor/256x256/apps
	cp vendor/data/tmjmenu.png debian/tmjmenu/usr/share/icons/hicolor/256x256/apps/
	mkdir -p debian/tmjmenu/usr/share/pixmaps
	cp vendor/data/tmjmenu.png debian/tmjmenu/usr/share/pixmaps/tmjmenu.png

	mkdir -p debian/tmjmenu/etc/xdg/autostart
	cp vendor/data/tmjdock.desktop           debian/tmjmenu/etc/xdg/autostart/
	cp vendor/data/tmjmenu-first-run.desktop debian/tmjmenu/etc/xdg/autostart/

override_dh_auto_test:
