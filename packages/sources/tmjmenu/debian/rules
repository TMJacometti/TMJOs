#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	@if [ ! -d vendor/tmjmenu ]; then \
		echo ""; \
		echo "ERROR: vendor/tmjmenu/ missing."; \
		echo "Run tools/vendor-tmjmenu.sh from the repo root."; \
		echo ""; \
		exit 1; \
	fi

	# Python module → /opt/tmjmenu/tmjmenu/
	mkdir -p debian/tmjmenu/opt/tmjmenu
	cp -r vendor/tmjmenu debian/tmjmenu/opt/tmjmenu/
	chmod -R a+rX debian/tmjmenu/opt/tmjmenu

	# Wrapper scripts + first-run → /usr/bin
	mkdir -p debian/tmjmenu/usr/bin
	cp vendor/tmjmenu-launcher.sh debian/tmjmenu/usr/bin/tmjmenu
	cp vendor/tmjdock-launcher.sh debian/tmjmenu/usr/bin/tmjdock
	cp vendor/tmjmenu-first-run  debian/tmjmenu/usr/bin/tmjmenu-first-run
	chmod +x debian/tmjmenu/usr/bin/tmjmenu \
	         debian/tmjmenu/usr/bin/tmjdock \
	         debian/tmjmenu/usr/bin/tmjmenu-first-run

	# Desktop entries
	mkdir -p debian/tmjmenu/usr/share/applications
	cp vendor/tmjmenu.desktop debian/tmjmenu/usr/share/applications/

	# AppStream metadata pra TMJStore descobrir o app
	mkdir -p debian/tmjmenu/usr/share/metainfo
	cp vendor/tmjmenu.appdata.xml \
		debian/tmjmenu/usr/share/metainfo/br.com.tmjsistemas.tmjmenu.appdata.xml

	# Autostart (system-wide):
	#   tmjdock.desktop — sobe a dock no login
	#   tmjmenu-first-run.desktop — configura Super+Space keybinding
	mkdir -p debian/tmjmenu/etc/xdg/autostart
	cp vendor/tmjdock.desktop           debian/tmjmenu/etc/xdg/autostart/
	cp vendor/tmjmenu-first-run.desktop debian/tmjmenu/etc/xdg/autostart/
