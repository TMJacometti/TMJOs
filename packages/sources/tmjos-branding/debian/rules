#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	@if [ ! -d vendor/branding ]; then \
		echo "ERROR: vendor/branding/ missing. Run tools/vendor-branding.sh"; \
		exit 1; \
	fi

	# Wallpapers
	mkdir -p debian/tmjos-branding/usr/share/backgrounds/tmjos
	cp vendor/branding/wallpapers/*.png \
		debian/tmjos-branding/usr/share/backgrounds/tmjos/

	# Logos (3 variantes em /usr/share/icons/tmjos/)
	mkdir -p debian/tmjos-branding/usr/share/icons/tmjos
	cp vendor/branding/logos/*.png \
		debian/tmjos-branding/usr/share/icons/tmjos/

	# Logo "tmjos" como system icon (Rounded variant)
	mkdir -p debian/tmjos-branding/usr/share/icons/hicolor/512x512/apps
	mkdir -p debian/tmjos-branding/usr/share/pixmaps
	cp vendor/branding/logos/TMJOs_Logo_Rounded.png \
		debian/tmjos-branding/usr/share/icons/hicolor/512x512/apps/tmjos.png
	cp vendor/branding/logos/TMJOs_Logo_Rounded.png \
		debian/tmjos-branding/usr/share/pixmaps/tmjos.png

	# Plymouth theme
	mkdir -p debian/tmjos-branding/usr/share/plymouth/themes/tmjos
	cp -r vendor/branding/plymouth/. \
		debian/tmjos-branding/usr/share/plymouth/themes/tmjos/
