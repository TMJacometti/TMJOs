#!/bin/sh
# postinst do tmjos-branding — aplica os assets recém-instalados.
set -e

case "$1" in
    configure)
        # 1) Atualiza icon cache do hicolor pra "tmjos" icon resolver
        if command -v gtk-update-icon-cache >/dev/null 2>&1; then
            gtk-update-icon-cache --quiet --force /usr/share/icons/hicolor || true
        fi

        # 2) Registra o tema TMJOs como default do Plymouth via alternatives
        if command -v update-alternatives >/dev/null 2>&1; then
            update-alternatives --install \
                /usr/share/plymouth/themes/default.plymouth default.plymouth \
                /usr/share/plymouth/themes/tmjos/tmjos.plymouth 200 \
                2>/dev/null || true
            update-alternatives --set default.plymouth \
                /usr/share/plymouth/themes/tmjos/tmjos.plymouth \
                2>/dev/null || true
        fi

        # 3) Regenera initramfs pra Plymouth pegar o tema novo
        # (silencioso se falhar — em chroots e containers pode não funcionar)
        if command -v update-initramfs >/dev/null 2>&1; then
            update-initramfs -u 2>&1 | head -20 || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
