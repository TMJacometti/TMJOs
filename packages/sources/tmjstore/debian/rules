#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	@if [ ! -f vendor/Cargo.toml ]; then \
		echo "ERROR: vendor/Cargo.toml missing. Run tools/vendor-tmjstore.sh first."; \
		exit 1; \
	fi
	cd vendor && cargo build --release --offline --locked

override_dh_auto_install:
	mkdir -p debian/tmjstore/usr/bin
	cp vendor/target/release/tmjstore debian/tmjstore/usr/bin/tmjstore
	chmod +x debian/tmjstore/usr/bin/tmjstore

	mkdir -p debian/tmjstore/usr/share/applications
	cp vendor/data/tmjstore.desktop debian/tmjstore/usr/share/applications/

	mkdir -p debian/tmjstore/usr/share/metainfo
	cp vendor/data/tmjstore.appdata.xml \
		debian/tmjstore/usr/share/metainfo/br.com.tmjsistemas.tmjstore.appdata.xml

	mkdir -p debian/tmjstore/usr/share/icons/hicolor/512x512/apps
	cp vendor/data/tmjstore.png debian/tmjstore/usr/share/icons/hicolor/512x512/apps/
	mkdir -p debian/tmjstore/usr/share/icons/hicolor/256x256/apps
	cp vendor/data/tmjstore.png debian/tmjstore/usr/share/icons/hicolor/256x256/apps/
	mkdir -p debian/tmjstore/usr/share/pixmaps
	cp vendor/data/tmjstore.png debian/tmjstore/usr/share/pixmaps/tmjstore.png

override_dh_auto_test:
