#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	@if [ ! -d vendor ]; then \
		echo "ERROR: vendor/ missing. Run tools/vendor-calamares-branding.sh"; \
		exit 1; \
	fi

	# /usr/share/calamares/branding/tmjos/ — Debian-idiomatic path for
	# read-only data. Calamares search paths include /usr/share/calamares/
	# branding/ automatically.
	mkdir -p debian/tmjos-calamares-branding/usr/share/calamares/branding/tmjos

	# Source files (branding.desc + show.qml)
	cp files/branding.desc \
		debian/tmjos-calamares-branding/usr/share/calamares/branding/tmjos/
	cp files/show.qml \
		debian/tmjos-calamares-branding/usr/share/calamares/branding/tmjos/

	# Vendored assets (PNGs)
	cp vendor/logo.png \
		debian/tmjos-calamares-branding/usr/share/calamares/branding/tmjos/
	cp vendor/welcome.png \
		debian/tmjos-calamares-branding/usr/share/calamares/branding/tmjos/
