#!/bin/sh
# postinst do tmjos-defaults
#   1. recompila o dconf db local pra os overrides ficarem ativos
#   2. força sessão X11 no GDM (necessário pra Plank — Plank só
#      funciona em X11, não suporta Wayland)
#   3. slim aggressive runtime: mascarar services pesados que causam
#      travas periódicas (descobertos em testing v1.3.4)
set -e

case "$1" in
    configure)
        if command -v dconf >/dev/null 2>&1; then
            dconf update || true
        fi

        # Force X11 session (disable Wayland) — Plank requires X11.
        GDM_CONF=/etc/gdm3/custom.conf
        if [ -f "$GDM_CONF" ]; then
            if grep -qE '^[[:space:]]*#?[[:space:]]*WaylandEnable=' "$GDM_CONF"; then
                sed -i 's/^[[:space:]]*#\?[[:space:]]*WaylandEnable=.*/WaylandEnable=false/' "$GDM_CONF"
            else
                if grep -qE '^\[daemon\]' "$GDM_CONF"; then
                    sed -i '/^\[daemon\]/a WaylandEnable=false' "$GDM_CONF"
                else
                    printf '\n[daemon]\nWaylandEnable=false\n' >> "$GDM_CONF"
                fi
            fi
        fi

        # Slim aggressive runtime — masks services que causam travas
        # periódicas em VMs e adicionam I/O / RAM overhead em hardware
        # real sem benefício pra distro dev-focused. Conservador: só
        # mascara serviços que NÃO afetam compat com hardware (cups,
        # bluetooth, avahi ficam intocados — se o user precisa, eles
        # funcionam normalmente).
        #
        # Mascarados (foreach idempotente — re-rodar é no-op):
        #   plymouth-quit-wait: bug conhecido que adiciona 20+s ao boot
        #                       (Plymouth não termina propriamente).
        #   unattended-upgrades: auto-updates em background travam o
        #                        sistema periodicamente. User decide
        #                        quando atualizar via apt.
        #   packagekit:         backend gráfico pra apt indexing.
        #                       Combinado com gnome-software (já
        #                        removido pelo slim), inútil.
        #   kerneloops:         telemetria de kernel crashes pra Ubuntu.
        #                        TMJOs já é distro independente.
        for svc in plymouth-quit-wait.service \
                   unattended-upgrades.service \
                   packagekit.service \
                   kerneloops.service; do
            if systemctl list-unit-files "$svc" 2>/dev/null | grep -q "$svc"; then
                systemctl stop "$svc" 2>/dev/null || true
                systemctl mask "$svc" 2>/dev/null || true
            fi
        done

        # Snapd: customize.sh remove durante o build do ISO, mas
        # alguns paths (ex: Ubuntu installer no disco) podem trazer
        # de volta. Re-purge aqui garante limpeza permanente.
        # TMJOs não usa snap — distribuição via apt repo próprio.
        if dpkg-query -W -f='${Status}' snapd 2>/dev/null | grep -q "^install ok installed$"; then
            systemctl stop snapd snapd.socket snapd.seeded.service 2>/dev/null || true
            DEBIAN_FRONTEND=noninteractive apt-get purge -y snapd 2>/dev/null || true
            rm -rf /var/cache/snapd /root/snap 2>/dev/null || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
