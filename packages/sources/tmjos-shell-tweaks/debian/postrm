#!/bin/sh
# postrm do tmjos-shell-tweaks — desfaz dpkg-divert e restaura
# os arquivos originais do tema Yaru.
set -e

undo() {
    css="$1"
    # Se a divert existe, remove e o original volta
    if dpkg-divert --list "$css" 2>/dev/null | grep -q "$css"; then
        rm -f "$css"
        dpkg-divert --quiet --local --rename --remove "$css" || true
    fi
}

case "$1" in
    remove|purge)
        undo /usr/share/gnome-shell/theme/Yaru/gnome-shell.css
        undo /usr/share/gnome-shell/theme/Yaru-dark/gnome-shell.css
        undo /usr/share/gnome-shell/gnome-shell.css
        ;;
esac

#DEBHELPER#

exit 0
