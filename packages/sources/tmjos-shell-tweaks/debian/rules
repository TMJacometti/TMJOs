#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	# Extension goes to system-wide GNOME Shell extensions dir
	EXT_DIR=debian/tmjos-shell-tweaks/usr/share/gnome-shell/extensions/tmjos-tweaks@tmjos.local; \
	mkdir -p "$$EXT_DIR"; \
	install -m644 files/extension/metadata.json "$$EXT_DIR/metadata.json"; \
	install -m644 files/extension/extension.js  "$$EXT_DIR/extension.js"
