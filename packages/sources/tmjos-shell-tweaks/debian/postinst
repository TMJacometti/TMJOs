#!/bin/sh
# postinst do tmjos-shell-tweaks 1.3.0-3 (no-op)
#
# Cleanup migration: se a 1.3.0-1 deixou um dpkg-divert no Yaru
# theme, desfaz pra o upstream voltar a servir o arquivo.
# Idempotente — não faz nada se a divert já não existe.

set -e

undo_divert() {
    css="$1"
    if dpkg-divert --list "$css" 2>/dev/null | grep -q "$css"; then
        rm -f "$css"
        dpkg-divert --quiet --local --rename --remove "$css" || true
    fi
}

case "$1" in
    configure)
        undo_divert /usr/share/gnome-shell/theme/Yaru/gnome-shell.css
        undo_divert /usr/share/gnome-shell/theme/Yaru-dark/gnome-shell.css
        undo_divert /usr/share/gnome-shell/gnome-shell.css
        ;;
esac

#DEBHELPER#

exit 0
