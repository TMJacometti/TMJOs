#!/bin/sh
# postinst do tmjos-shell-tweaks — usa dpkg-divert pra modificar
# arquivos do tema Yaru de forma reversível.
set -e

SNIPPET=/usr/share/tmjos-shell-tweaks/hide-activities.css

apply_to() {
    css="$1"
    [ -f "$css" ] || return 0

    # Marker check — se já aplicado, skip
    if grep -q "TMJOs hide activities" "$css" 2>/dev/null; then
        return 0
    fi

    # Divert original out of the way (rename → .tmjos-orig)
    dpkg-divert --quiet --local --rename \
        --divert "${css}.tmjos-orig" --add "$css"

    # Restore original content + append our snippet
    cp "${css}.tmjos-orig" "$css"
    cat "$SNIPPET" >> "$css"
}

case "$1" in
    configure)
        apply_to /usr/share/gnome-shell/theme/Yaru/gnome-shell.css
        apply_to /usr/share/gnome-shell/theme/Yaru-dark/gnome-shell.css
        # Yaru baseline (sem -dark) também — alguns sistemas só têm essa
        apply_to /usr/share/gnome-shell/gnome-shell.css
        ;;
esac

#DEBHELPER#

exit 0
