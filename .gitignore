# ==============================================
# TMJOs - .gitignore
# ==============================================

# Build artifacts (Cubic project & ISO output)
build/
output/
tmjos-build/
*.iso
*.iso.md5
*.iso.sha256
*.iso.sha512
*.img

# Local-only files (notas pessoais, rascunhos, refs)
.local/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary
*.tmp
*.bak
*.cache

# Secrets
.env
.env.local
secrets/
*.key
*.pem

# GPG private keys — NUNCA commitar
*-private-key*.asc
*.gpg-secret*
private-keys-v1.d/

# Build artefatos de packages
packages/sources/**/debian/files
packages/sources/**/debian/*.substvars
packages/sources/**/debian/*.debhelper.log
packages/sources/**/debian/.debhelper/
packages/sources/**/debian/<pkg>/
packages/sources/**/debian/tmp/
packages/dist/
packages/*.deb
packages/*.changes
packages/*.buildinfo
packages/*.dsc
packages/*.tar.*
packages/db/
packages/lists/
packages/incoming/

# Vendored upstream files (re-populados pelo tools/vendor-*.sh antes do build)
packages/sources/*/vendor/
