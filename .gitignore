.local/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary
*.tmp
*.bak
*.cache

# Secrets
.env
.env.local
secrets/
*.key
*.pem
